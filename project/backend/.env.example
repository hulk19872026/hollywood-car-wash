# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# Optional override; defaults to claude-opus-4-7
ANTHROPIC_MODEL=claude-opus-4-7

# ---- Email (Nodemailer over SMTP) ----
# Defaults to smtp.gmail.com:587 (STARTTLS) — works reliably on Railway.
# Override host/port for a different provider (Outlook, Yahoo, custom SMTP, etc.)
EMAIL_USER=you@example.com
EMAIL_PASS=your-app-password
# Optional overrides:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false  # true for port 465, false for 587/STARTTLS

# ---- Server ----
# Railway sets PORT automatically; only needed locally.
PORT=3000
NODE_ENV=production
