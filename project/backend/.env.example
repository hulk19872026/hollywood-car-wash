# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# Optional override; defaults to claude-opus-4-7
ANTHROPIC_MODEL=claude-opus-4-7

# ---- Email (Resend, HTTPS) ----
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_your_resend_api_key_here
# Optional sender override. Defaults to "Hollywood Oil Change <onboarding@resend.dev>",
# which works without DNS verification but ONLY delivers to the email used
# to register the Resend account. For production, verify a domain in the
# Resend dashboard and set this to e.g. "Hollywood Oil Change <reports@yourdomain.com>".
# RESEND_FROM=Hollywood Oil Change <reports@yourdomain.com>

# ---- Server ----
# Railway sets PORT automatically; only needed locally.
PORT=3000
NODE_ENV=production
